{
  "backends": {
    "inber": {
      "type": "cli",
      "cmd": ["~/bin/inber", "run", "-a", "{agent}"],
      "dir": "~/life/repos/inber",
      "stdin": "json",
      "features": ["meta", "spawns", "inject"]
    },
    "openclaw": {
      "type": "openai",
      "url": "http://127.0.0.1:18789",
      "token": "${OPENCLAW_GATEWAY_TOKEN}",
      "model": "openclaw",
      "agent_header": "x-openclaw-agent-id",
      "timeout": "10m"
    },
    "claude-code": {
      "type": "cli",
      "cmd": ["claude", "--print"],
      "stdin": "text",
      "timeout": "15m"
    },
    "codex": {
      "type": "cli",
      "cmd": ["codex", "--quiet"],
      "stdin": "text",
      "timeout": "15m"
    }
  },
  "agents": {
    "oc-main": "openclaw",
    "coder": "claude-code"
  },
  "routes": [
    {"channel": "discord", "agent": "claxon"},
    {"channel": "dashboard", "agent": "claxon"}
  ],
  "default_backend": "inber",
  "default_agent": "claxon"
}
